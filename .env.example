# ============================================================================
# OneAce — Environment Variables
# ============================================================================
# Copy this file to `.env` and fill in real values for local development.
# In production (Vercel), set these in Settings > Environment Variables.
#
# Legend:
#   REQUIRED  — server refuses to boot without it
#   PAIRED    — must be set together or both omitted
#   OPTIONAL  — sensible default or graceful fallback when unset
# ============================================================================

# --- Database (Neon Postgres) — REQUIRED ------------------------------------
# Pooled connection (PgBouncer) for runtime queries.
DATABASE_URL="postgresql://<user>:<password>@ep-xxxx.eu-central-1.aws.neon.tech/oneace?sslmode=require"
# Unpooled (direct) connection for Prisma migrations and introspection.
DIRECT_URL="postgresql://<user>:<password>@ep-xxxx.eu-central-1.aws.neon.tech/oneace?sslmode=require"

# --- Better Auth — REQUIRED -------------------------------------------------
# HMAC signing key for session cookies. Minimum 32 characters.
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Absolute URL of the running app (used for email callbacks, cookie domain).
BETTER_AUTH_URL="http://localhost:3000"

# --- Public app URL — OPTIONAL ----------------------------------------------
# Embedded in the client bundle. Used for invitation email links and
# Better Auth trusted-origin allowlist. If unset in production, links
# will point to localhost (a startup warning is logged).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="OneAce"

# --- Email (Resend) — PAIRED, OPTIONAL --------------------------------------
# Set both to enable outbound email (invitations, password resets,
# low-stock digests). Leave both unset to fall back to console logging.
RESEND_API_KEY=""
MAIL_FROM="OneAce <noreply@oneace.app>"

# --- Rate limiting (Upstash Redis REST) — PAIRED, OPTIONAL ------------------
# Set both to enable distributed rate limiting (required in production
# for multi-instance safety). Leave both unset for in-process fallback
# (dev only — NOT safe for multi-instance deployments).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Registration gate — OPTIONAL (default: true) ---------------------------
# When "false", /register redirects to /login and the sign-up API
# returns 403. Launch sequence: deploy with "true" -> create first
# owner account -> flip to "false" -> all future users join via invite.
# Accepts: "true" | "false" | "1" | "0"
REGISTRATION_ENABLED="true"

# --- Cron authentication — OPTIONAL -----------------------------------------
# Shared secret for cron-triggered routes (e.g. /api/cron/notifications).
# If unset, cron endpoints return 503 (safe default). Minimum 16 chars.
# Generate with: openssl rand -base64 24
CRON_SECRET=""

# --- Observability — OPTIONAL -----------------------------------------------
# Structured logger threshold. Defaults to "info" in production,
# "debug" in development.
# Accepts: "debug" | "info" | "warn" | "error"
LOG_LEVEL=""

# --- Audit retention — OPTIONAL (default: 365) ------------------------------
# Days to retain AuditEvent rows. Used by `pnpm audit:prune`.
# Minimum 1. Default 365 (one-year compliance floor).
AUDIT_RETENTION_DAYS=""

# --- Health check — OPTIONAL ------------------------------------------------
# Expected number of applied Prisma migrations. When set, /api/health
# verifies the count matches. When unset, the migrations sub-check
# reports "skipped" (acceptable during development).
EXPECTED_MIGRATION_COUNT=""

# --- Future / not yet wired -------------------------------------------------
# These vars are placeholders for planned integrations. They are NOT
# read by any code today and can be left empty.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.posthog.com"
UPLOADTHING_TOKEN=""
