# Database (Neon Postgres)
# dev branch
DATABASE_URL="postgresql://<user>:<password>@ep-xxxx.eu-central-1.aws.neon.tech/oneace?sslmode=require"
# direct connection for prisma migrate (Neon pooled URL fails with migrations)
