# Next.js — absolute URL of the deployed app. Used for invitation
# emails, OAuth callbacks, and the Better Auth trusted-origin
# allowlist. Optional in local dev (falls back to http://localhost:3000).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database (Neon Postgres) — both URLs are REQUIRED.
# DATABASE_URL is the pooled (PgBouncer) connection used by the app.
# DIRECT_URL is the unpooled connection used by prisma migrate.
DATABASE_URL="postgresql://<user>:<password>@ep-xxxx.eu-central-1.aws.neon.tech/oneace?sslmode=require"
DIRECT_URL="postgresql://<user>:<password>@ep-xxxx.eu-central-1.aws.neon.tech/oneace?sslmode=require"

# Better Auth — session signing + absolute URL for email flows.
# BETTER_AUTH_SECRET must be at least 32 characters. Generate with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# Email (Resend) — optional pair. When both set, outbound email is
# sent via Resend. When both unset, src/lib/mail logs messages to
# stdout instead (dev-loop behaviour). Having only one half of the
# pair is a schema failure (see src/lib/env.ts superRefine).
RESEND_API_KEY=""
MAIL_FROM="OneAce <noreply@oneace.app>"

# Logger (Sprint 37) — optional. Threshold for the in-house logger at
# src/lib/logger.ts. Defaults to "debug" in dev, "info" in production.
# Allowed values: debug | info | warn | error
LOG_LEVEL=""

# Rate limiting (Phase 6A / P2) — optional pair. When both set, the
# rate limiter at src/lib/rate-limit.ts uses an Upstash Redis REST
# sliding window (distributed, safe for multi-instance). When both
# unset, it falls back to an in-process Map (single-instance only,
# NOT safe for production multi-instance). Having only one half of
# the pair is a schema failure (see src/lib/env.ts superRefine).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
