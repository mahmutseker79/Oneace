{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "surface": {
      "default": { "light": "hsl(0 0% 100%)", "dark": "hsl(222 47 4)" },
      "muted": { "light": "hsl(210 40 96)", "dark": "hsl(217 33 10)" },
      "raised": { "light": "hsl(0 0% 100%)", "dark": "hsl(222 47 7)" },
      "container": { "light": "hsl(210 40 98)", "dark": "hsl(222 47 6)" },
      "overlay": { "light": "hsl(222 47 11 / 0.6)", "dark": "hsl(0 0% 0 / 0.7)" }
    },
    "text": {
      "primary": { "light": "hsl(222 47 11)", "dark": "hsl(210 40 98)" },
      "secondary": { "light": "hsl(215 16 47)", "dark": "hsl(215 20 65)" },
      "muted": { "light": "hsl(215 16 58)", "dark": "hsl(215 20 55)" },
      "on_primary": { "light": "hsl(210 40 98)", "dark": "hsl(222 47 11)" },
      "destructive": { "light": "hsl(0 72 45)", "dark": "hsl(0 85 65)" }
    },
    "border": {
      "default": { "light": "hsl(214 32 91)", "dark": "hsl(217 33 18)" },
      "subtle": { "light": "hsl(214 32 95)", "dark": "hsl(217 33 13)" }
    },
    "ring": {
      "focus": { "light": "hsl(222 84 5)", "dark": "hsl(210 40 90)" }
    },
    "action": {
      "primary": {
        "bg": { "light": "hsl(222 47 11)", "dark": "hsl(210 40 98)" },
        "fg": { "light": "hsl(210 40 98)", "dark": "hsl(222 47 11)" },
        "hover": { "light": "hsl(222 47 20)", "dark": "hsl(210 40 90)" }
      },
      "destructive": {
        "bg": { "light": "hsl(0 72 45)", "dark": "hsl(0 85 50)" },
        "fg": { "light": "hsl(0 0 100)", "dark": "hsl(0 0 100)" }
      }
    },
    "status": {
      "stock": {
        "critical": { "light": "hsl(0 72 45)", "dark": "hsl(0 85 65)" },
        "low": { "light": "hsl(25 90 50)", "dark": "hsl(25 90 60)" },
        "normal": { "light": "hsl(142 70 36)", "dark": "hsl(142 60 55)" },
        "high": { "light": "hsl(199 89 48)", "dark": "hsl(199 80 60)" },
        "excess": { "light": "hsl(262 52 47)", "dark": "hsl(262 60 70)" }
      },
      "count": {
        "open": { "light": "hsl(217 91 60)", "dark": "hsl(217 91 65)" },
        "in_progress": { "light": "hsl(38 92 50)", "dark": "hsl(38 92 60)" },
        "completed": { "light": "hsl(142 70 36)", "dark": "hsl(142 60 55)" },
        "cancelled": { "light": "hsl(215 16 58)", "dark": "hsl(215 20 45)" }
      },
      "variance": {
        "match": { "light": "hsl(142 70 36)", "dark": "hsl(142 60 55)" },
        "within_tolerance": { "light": "hsl(199 89 48)", "dark": "hsl(199 80 60)" },
        "over": { "light": "hsl(38 92 50)", "dark": "hsl(38 92 60)" },
        "under": { "light": "hsl(0 72 45)", "dark": "hsl(0 85 65)" }
      },
      "sync": {
        "online": { "light": "hsl(142 70 36)", "dark": "hsl(142 60 55)" },
        "offline": { "light": "hsl(215 16 58)", "dark": "hsl(215 20 45)" },
        "syncing": { "light": "hsl(199 89 48)", "dark": "hsl(199 80 60)" },
        "error": { "light": "hsl(0 72 45)", "dark": "hsl(0 85 65)" },
        "conflict": { "light": "hsl(25 90 50)", "dark": "hsl(25 90 60)" }
      },
      "scan": {
        "ready": { "light": "hsl(217 91 60)", "dark": "hsl(217 91 65)" },
        "success": { "light": "hsl(142 70 36)", "dark": "hsl(142 60 55)" },
        "error": { "light": "hsl(0 72 45)", "dark": "hsl(0 85 65)" },
        "not_found": { "light": "hsl(38 92 50)", "dark": "hsl(38 92 60)" }
      }
    }
  },
  "typography": {
    "family": {
      "sans": "Inter, ui-sans-serif, system-ui, sans-serif",
      "mono": "ui-monospace, SFMono-Regular, Menlo, monospace"
    },
    "scale": {
      "display": { "size": 32, "lineHeight": 40, "weight": 600 },
      "headline": { "size": 24, "lineHeight": 32, "weight": 600 },
      "title": { "size": 18, "lineHeight": 28, "weight": 600 },
      "body": { "size": 14, "lineHeight": 20, "weight": 400 },
      "body_strong": { "size": 14, "lineHeight": 20, "weight": 500 },
      "label": { "size": 12, "lineHeight": 16, "weight": 500 },
      "caption": { "size": 12, "lineHeight": 16, "weight": 400 },
      "numeric_lg": { "size": 28, "lineHeight": 36, "weight": 600, "tabular": true },
      "numeric_md": { "size": 18, "lineHeight": 24, "weight": 600, "tabular": true },
      "numeric_sm": { "size": 14, "lineHeight": 20, "weight": 500, "tabular": true },
      "mono_sku": { "size": 12, "lineHeight": 16, "weight": 500, "family": "mono" }
    }
  },
  "spacing": {
    "0": 0,
    "1": 4,
    "2": 8,
    "3": 12,
    "4": 16,
    "6": 24,
    "8": 32,
    "10": 40,
    "12": 48,
    "16": 64
  },
  "radius": {
    "sm": 4,
    "md": 6,
    "lg": 8,
    "xl": 12,
    "full": 9999
  },
  "shadow": {
    "sm": "0 1px 2px 0 hsl(222 47 11 / 0.05)",
    "md": "0 4px 6px -1px hsl(222 47 11 / 0.08), 0 2px 4px -2px hsl(222 47 11 / 0.05)",
    "lg": "0 10px 15px -3px hsl(222 47 11 / 0.10), 0 4px 6px -4px hsl(222 47 11 / 0.05)",
    "xl": "0 20px 25px -5px hsl(222 47 11 / 0.12), 0 8px 10px -6px hsl(222 47 11 / 0.06)"
  },
  "motion": {
    "duration": {
      "fast": 150,
      "default": 200,
      "slow": 300
    },
    "ease": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "decelerate": "cubic-bezier(0, 0, 0, 1)",
      "accelerate": "cubic-bezier(0.3, 0, 1, 1)"
    }
  },
  "icon": {
    "xs": 12,
    "sm": 14,
    "md": 16,
    "lg": 20,
    "xl": 24
  },
  "touchTarget": {
    "min": 44
  },
  "breakpoint": {
    "mobile": 0,
    "tablet_p": 640,
    "tablet_l": 1024,
    "desktop": 1280
  }
}
