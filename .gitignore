.vscode
.idea

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# prisma
prisma/*.db
prisma/*.db-journal
prisma/schema.tmp.prisma
src/generated/

# coverage
coverage
.nyc_output

# P3-2 (audit v1.1 §5.31) — scratch outputs from manual test / audit
# runs. These belong in a developer's local scratch area, not the
# committed tree. `test-artifacts/` is the P8 manual-regression dump;
# `TEST_REPORT.md` is a per-session rollup; `test-results/` and
# `playwright-report/` are the default Playwright output sinks.
/test-artifacts/
/TEST_REPORT.md
/test-results/
/playwright-report/

# P3-2 (audit v1.1 §5.31) — FUSE-sandbox trash names. When a file
# cannot be unlinked in the Cowork FUSE mount (common for read-only
# source dumps), the delete is simulated by renaming it to a dotfile
# trash name. Never commit those.
.*.trash.*
src/app/.*.trash.*

# vercel
.vercel

# port workflow — git bundle exports produced by the Flutter→Next
# port tagging workflow. Never commit these.
*.bundle
*.bundle.old

# sandbox temp files — pnpm writes `_tmp_*` probe files in the
# project root when resolving the store path. These are zero-byte
# and should never be committed.
_tmp_*

# sandbox tsconfig — local FUSE-mount workaround remapping
# @/generated/prisma to an out-of-mount client. Dev ergonomics
# only; not part of the canonical build.
tsconfig.sandbox.json

# historical TypeScript incremental build info backups from prior
# port sprints. The active `*.tsbuildinfo` pattern above doesn't
# catch these because the extension is `.old`, `.old2`, `.old10b`, ...
tsconfig.tsbuildinfo.old*
oneace
oneace.pub

# User uploads
public/uploads/

# Claude agent worktrees (sandbox artifacts)
.claude/worktrees/

# Escaped parenthesis directories (Finder artifacts)
src/app/\\(app\\)/

# God-Mode v2 §5 — Phase 5 — repo hygiene.
#
# FUSE-rename workaround. When the Cowork sandbox can't unlink a
# file (common for large generated-client dumps under
# `src/generated/`), the delete falls back to `mv foo foo.gone`.
# That leaves stale `*.gone` names in the working tree until the
# next fresh checkout. Never commit them.
*.gone

# Playwright CLI cache — the Chrome controller MCP writes its
# per-session page/console snapshots here. Local-only debug output.
/.playwright-cli/

# npm lockfile — this project is pnpm-only (see `packageManager`
# field in package.json). An accidental `npm install` generates
# package-lock.json and it must not land in the repo alongside
# pnpm-lock.yaml or Vercel will resolve dependencies twice.
/package-lock.json

# Kickoff prompts — per-phase prompt text files used to kick off a
# new agent session. They're scratch and change every session.
# (Note: `push-*.command` / `push-*.log` are deliberately tracked as
# sprint release artefacts, per the project's release workflow.)
/*-KICKOFF-PROMPT.md

# Recovery staging dir (2026-04-24 GOD MODE transcript recovery)
.recovery-stage/

# Repo-root-only ephemeral .command helpers. Hotfix / apply / merge /
# finish scripts are generated at the root during a sprint and should
# be archived under scripts/recovery/<date>-<name>/ once the sprint
# lands. This block prevents them from accumulating at the root.
# `push-*.command` remains DELIBERATELY tracked (release artefact — see
# the comment above `/*-KICKOFF-PROMPT.md`).
/hotfix-*.command
/apply-*.command
/apply-*.sh
/merge-*.command
/finish-*.command
/sprint-*.command
