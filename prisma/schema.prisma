  ITEM
  SUPPLIER
  WAREHOUSE
  PURCHASE_ORDER
}

// Phase MIG-S1 — Runtime type of a custom field. The ItemCustomFieldValue
// table stores the value in a typed column based on this (valueText,
// valueNumber, valueDate, valueBoolean, or valueJson for MULTI_SELECT).
// Only one column is populated per row; the rest are null.
enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTI_SELECT
  URL
}

enum MigrationStatus {
  PENDING
  FILES_UPLOADED
  MAPPING_REVIEW
  VALIDATING
  VALIDATED
  IMPORTING
  COMPLETED
  FAILED
  CANCELLED
}

// =========================
// Phase 17+: Department
// =========================
//
// A department is an organizational unit that can own items and be
// assigned to stock counts. This is a first-mover feature — no
// competitor offers department-based counting.

model Department {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  code           String?
  color          String?
  managerId      String?
  warehouseId    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  manager          User?             @relation(fields: [managerId], references: [id], onDelete: SetNull)
  warehouse        Warehouse?        @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  stockCounts      StockCount[]
  countAssignments CountAssignment[]
  countTemplates   CountTemplate[]
  items            Item[]

  @@unique([organizationId, code])
  @@index([organizationId, isActive])
  @@index([managerId])
  @@index([warehouseId])
}

// =========================
// Phase 17+: Count Assignment (Multi-Counter)
// =========================
//
// Assigns a user to a specific count with a role (COUNTER, VERIFIER,
// SUPERVISOR). Enables concurrent multi-counter workflows where
// multiple people work on the same count simultaneously.

model CountAssignment {
  id             String           @id @default(cuid())
  organizationId String
  countId        String
  userId         String
  departmentId   String?
  warehouseId    String?
  role           CountRole        @default(COUNTER)
  status         AssignmentStatus @default(PENDING)
  startedAt      DateTime?
  completedAt    DateTime?
  itemsCounted   Int              @default(0)
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  count        StockCount   @relation(fields: [countId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@unique([countId, userId])
  @@index([organizationId, countId])
  @@index([userId, status])
  @@index([departmentId])
}

// =========================
// Phase 17+: Count Approval
// =========================
//
// Approval workflow for stock counts. When a count requires approval,
// it transitions to PENDING_APPROVAL after counting is complete, and
// a supervisor must approve or reject before stock is adjusted.

model CountApproval {
  id             String         @id @default(cuid())
  organizationId String
  countId        String         @unique
  requestedById  String
  reviewedById   String?
  status         ApprovalStatus @default(PENDING)
  comment        String?
  requestedAt    DateTime       @default(now())
  reviewedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  count        StockCount   @relation(fields: [countId], references: [id], onDelete: Cascade)
  requestedBy  User         @relation("ApprovalRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  reviewedBy   User?        @relation("ApprovalReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([countId])
  @@index([requestedById])
  @@index([reviewedById])
}

// =========================
// Phase 17+: Count Template
// =========================
//
// Reusable templates for creating stock counts with pre-configured
// scope, methodology, and schedule. Supports recurring counts via
// cron expressions.

model CountTemplate {
  id              String           @id @default(cuid())
  organizationId  String
  name            String
  description     String?
  methodology     CountMethodology
  scope           CountScope       @default(FULL)
  warehouseId     String?
  departmentId    String?
  categoryIds     String[]
  itemFilter      Json?
  isRecurring     Boolean          @default(false)
  cronExpression  String?
  nextScheduledAt DateTime?
  lastUsedAt      DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse?   @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  department   Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([isRecurring, nextScheduledAt])
  @@index([warehouseId])
  @@index([departmentId])
}

// =========================
// Phase 17+: Label Template
// =========================
//
// Customizable label templates for printing bin, item, and warehouse
// labels. Layout is stored as JSON with field positions and sizes.

model LabelTemplate {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  type           LabelType
  width          Float
  height         Float
  layout         Json
  barcodeFormat  BarcodeFormat @default(CODE128)
  isDefault      Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Phase V4: new zone label relation
  zoneLabels   ZoneLabel[]

  @@index([organizationId, type])
}

// =========================
// Phase 17+: Import Template
// =========================
//
// Reusable field mapping templates for importing data from external
// sources. Stores source-to-target field mappings and transform rules.

model ImportTemplate {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  source         ImportSource
  entityType     ImportEntity
  fieldMapping   Json
  transformRules Json?
  isDefault      Boolean      @default(false)
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobs         ImportJob[]

  @@index([organizationId, source])
}

// =========================
// Phase 17+: Import Job
// =========================
//
// Tracks the progress and results of an import operation. Stores
// row-level error details for user review.

model ImportJob {
  id              String       @id @default(cuid())
  organizationId  String
  templateId      String?
  source          ImportSource
  entityType      ImportEntity
  status          ImportStatus @default(PENDING)
  fileName        String?
  totalRows       Int          @default(0)
  processedRows   Int          @default(0)
  successRows     Int          @default(0)
  errorRows       Int          @default(0)
  errors          Json?
  startedAt       DateTime?
  completedAt     DateTime?
  createdByUserId String?
  createdAt       DateTime     @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     ImportTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdBy    User?           @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([templateId])
  @@index([createdByUserId])
}

// =========================
// Phase 17+: External Integration
// =========================
//
// Stores connection credentials and sync settings for external
// services (QuickBooks, Shopify, etc.). Credentials are encrypted
// at the application layer.

model Integration {
  id                String              @id @default(cuid())
  organizationId    String
  provider          IntegrationProvider
  status            IntegrationStatus   @default(DISCONNECTED)
  credentials       Json?
  settings          Json?
  lastSyncAt        DateTime?
  lastError         String?
  // Sync configuration
  syncFrequency     SyncFrequency       @default(MANUAL)
  syncDirection     SyncDirection       @default(BIDIRECTIONAL)
  conflictPolicy    ConflictPolicy      @default(REMOTE_WINS)
  retryPolicy       RetryPolicy         @default(EXPONENTIAL)
  maxRetries        Int                 @default(3)
  rateLimitPerMin   Int                 @default(60)
  // Feature flags per integration
  syncItems         Boolean             @default(true)
  syncOrders        Boolean             @default(true)
  syncSuppliers     Boolean             @default(false)
  syncCategories    Boolean             @default(false)
  syncStockLevels   Boolean             @default(true)
  syncPrices        Boolean             @default(true)
  syncImages        Boolean             @default(false)
  syncCustomers     Boolean             @default(false)
  // Filters
  syncFilterJson    Json?
  // Metadata
  externalAccountId String?
  externalStoreName String?
  webhookSecret     String?
  webhookUrl        String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  organization  Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncLogs      SyncLog[]
  fieldMappings IntegrationFieldMapping[]
  syncRules     IntegrationSyncRule[]
  webhookEvents IntegrationWebhookEvent[]
  syncSchedules IntegrationSyncSchedule[]

  @@unique([organizationId, provider])
}

// =========================
// IntegrationFieldMapping — custom field mapping between OneAce ↔ external
// =========================
model IntegrationFieldMapping {
  id            String        @id @default(cuid())
  integrationId String
  entityType    ImportEntity
  localField    String
  remoteField   String
  direction     SyncDirection @default(BIDIRECTIONAL)
  transformRule String?
  defaultValue  String?
  isRequired    Boolean       @default(false)
  isActive      Boolean       @default(true)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, entityType, localField])
  @@index([integrationId])
}

// =========================
// IntegrationSyncRule — conditional sync rules
// =========================
model IntegrationSyncRule {
  id            String         @id @default(cuid())
  integrationId String
  name          String
  entityType    ImportEntity
  condition     Json
  action        SyncRuleAction @default(SYNC)
  priority      Int            @default(0)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId])
}

// =========================
// IntegrationWebhookEvent — granular webhook event subscriptions
// =========================
model IntegrationWebhookEvent {
  id              String    @id @default(cuid())
  integrationId   String
  eventType       String
  endpointUrl     String
  isActive        Boolean   @default(true)
  secret          String?
  lastTriggeredAt DateTime?
  failCount       Int       @default(0)
  createdAt       DateTime  @default(now())

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, eventType, endpointUrl])
  @@index([integrationId])
}

// =========================
// IntegrationSyncSchedule — cron-based sync scheduling
// =========================
model IntegrationSyncSchedule {
  id             String        @id @default(cuid())
  integrationId  String
  entityType     ImportEntity
  direction      SyncDirection
  cronExpression String
  isActive       Boolean       @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  createdAt      DateTime      @default(now())

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, entityType, direction])
  @@index([integrationId])
}

// =========================
// Phase 17+: Sync Log
// =========================
//
// Records the outcome of each sync operation between OneAce and
// an external integration.

model SyncLog {
  id               String        @id @default(cuid())
  integrationId    String
  direction        SyncDirection
  entityType       ImportEntity
  status           ImportStatus
  recordsProcessed Int           @default(0)
  recordsCreated   Int           @default(0)
  recordsUpdated   Int           @default(0)
  recordsSkipped   Int           @default(0)
  recordsFailed    Int           @default(0)
  errors           Json?
  startedAt        DateTime      @default(now())
  completedAt      DateTime?

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, startedAt])
}

// =========================
// Phase 17+: Scheduled Report
// =========================
//
// Configures automated report generation and email delivery on a
// cron schedule.

model ScheduledReport {
  id              String       @id @default(cuid())
  organizationId  String
  name            String
  reportType      ReportType
  filters         Json?
  format          ExportFormat @default(PDF)
  cronExpression  String
  recipientEmails String[]
  isActive        Boolean      @default(true)
  lastSentAt      DateTime?
  nextSendAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, isActive])
  @@index([isActive, nextSendAt])
}

// =========================
// Phase V4: New Models
// =========================

// =========================
// ReasonCode — configurable reason codes for adjustments/variances
// =========================
model ReasonCode {
  id             String         @id @default(cuid())
  organizationId String
  code           String
  name           String
  category       ReasonCategory
  description    String?
  isActive       Boolean        @default(true)
  isDefault      Boolean        @default(false)
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // Back-references for V4 tracking
  stockMovements StockMovement[] @relation("MovementReasonCode")
  countEntries   CountEntry[]    @relation("EntryReasonCode")

  @@unique([organizationId, code])
  @@index([organizationId, category, isActive])
}

// =========================
// SerialNumber — serial number tracking with lifecycle
// =========================
model SerialNumber {
  id               String       @id @default(cuid())
  organizationId   String
  itemId           String
  variantId        String?
  serialNumber     String
  status           SerialStatus @default(IN_STOCK)
  warehouseId      String?
  binId            String?
  batchId          String?
  receivedDate     DateTime?
  soldDate         DateTime?
  lastMovedAt      DateTime?
  assignedToUserId String?
  note             String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item           Item                @relation(fields: [itemId], references: [id], onDelete: Cascade)
  history        SerialHistory[]
  // Back-references for V4 tracking
  stockMovements StockMovement[]     @relation("MovementSerial")
  countEntries   CountEntry[]        @relation("EntrySerial")
  transferLines  StockTransferLine[]

  @@unique([organizationId, serialNumber])
  @@index([organizationId, itemId])
  @@index([organizationId, status])
  @@index([serialNumber])
}

// =========================
// SerialHistory — serial number lifecycle events
// =========================
model SerialHistory {
  id                String       @id @default(cuid())
  serialNumberId    String
  action            SerialAction
  fromWarehouseId   String?
  toWarehouseId     String?
  reference         String?
  performedByUserId String?
  note              String?
  performedAt       DateTime     @default(now())

  serialNumber  SerialNumber @relation(fields: [serialNumberId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse?   @relation("HistoryFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: SetNull)
  toWarehouse   Warehouse?   @relation("HistoryToWarehouse", fields: [toWarehouseId], references: [id], onDelete: SetNull)
  performedBy   User?        @relation(fields: [performedByUserId], references: [id], onDelete: SetNull)

  @@index([serialNumberId, performedAt])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([performedByUserId])
}

// =========================
// ItemAttachment — multiple files per item
// =========================
model ItemAttachment {
  id               String         @id @default(cuid())
  organizationId   String
  itemId           String
  fileName         String
  fileUrl          String
  fileType         AttachmentType
  fileSize         Int
  sortOrder        Int            @default(0)
  uploadedByUserId String?
  createdAt        DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  uploadedBy   User?        @relation("UploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, itemId])
  @@index([uploadedByUserId])
}

// =========================
// SavedView — reusable filter presets
// =========================
model SavedView {
  id             String   @id @default(cuid())
  organizationId String
  userId         String?
  page           String
  name           String
  filters        Json
  sortBy         String?
  sortOrder      String?
  columns        String[]
  isDefault      Boolean  @default(false)
  isShared       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, page])
  @@index([userId, page])
  @@index([userId])
}

// =========================
// LocationLevel — zone/aisle/rack/shelf hierarchy
// =========================
model LocationLevel {
  id             String       @id @default(cuid())
  organizationId String
  warehouseId    String
  parentId       String?
  type           LocationType
  name           String
  code           String
  barcodeValue   String?
  sortOrder      Int          @default(0)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse    Warehouse       @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  parent       LocationLevel?  @relation("LocationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     LocationLevel[] @relation("LocationHierarchy")
  stockLevels  StockLevel[]

  @@unique([warehouseId, code])
  @@index([organizationId, warehouseId])
  @@index([parentId])
  @@index([warehouseId])
}

// =========================
// StockTransfer — transfers with in-transit state
// =========================
model StockTransfer {
  id               String         @id @default(cuid())
  organizationId   String
  transferNumber   String
  fromWarehouseId  String
  toWarehouseId    String
  status           TransferStatus @default(DRAFT)
  shippedAt        DateTime?
  receivedAt       DateTime?
  shippedByUserId  String?
  receivedByUserId String?
  note             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  organization  Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse           @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  toWarehouse   Warehouse           @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Restrict)
  shippedBy     User?               @relation("TransferShippedBy", fields: [shippedByUserId], references: [id], onDelete: SetNull)
  receivedBy    User?               @relation("TransferReceivedBy", fields: [receivedByUserId], references: [id], onDelete: SetNull)
  lines         StockTransferLine[]

  @@unique([organizationId, transferNumber])
  @@index([organizationId, status])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([shippedByUserId])
  @@index([receivedByUserId])
}

// =========================
// StockTransferLine — transfer line items
// =========================
model StockTransferLine {
  id             String  @id @default(cuid())
  organizationId String
  transferId     String
  itemId         String
  variantId      String?
  batchId        String?
  serialNumberId String?
  shippedQty     Int
  receivedQty    Int     @default(0)
  discrepancy    Int     @default(0)
  note           String?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transfer     StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  item         Item          @relation("TransferLineItem", fields: [itemId], references: [id], onDelete: Restrict)
  variant      ItemVariant?  @relation(fields: [variantId], references: [id], onDelete: SetNull)
  batch        ItemBatch?    @relation(fields: [batchId], references: [id], onDelete: SetNull)
  serialNumber SerialNumber? @relation(fields: [serialNumberId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([transferId])
  @@index([itemId])
  @@index([variantId])
  @@index([batchId])
  @@index([serialNumberId])
}

// =========================
// SalesOrder — sales orders for allocation
// =========================
model SalesOrder {
  id              String           @id @default(cuid())
  organizationId  String
  orderNumber     String
  customerName    String?
  customerRef     String?
  status          SalesOrderStatus @default(DRAFT)
  orderDate       DateTime         @default(now())
  requiredDate    DateTime?
  shippedAt       DateTime?
  note            String?
  createdByUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  lines        SalesOrderLine[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId, status])
}

// =========================
// SalesOrderLine — sales order line items
// =========================
model SalesOrderLine {
  id             String  @id @default(cuid())
  organizationId String
  salesOrderId   String
  itemId         String
  variantId      String?
  warehouseId    String
  orderedQty     Int
  allocatedQty   Int     @default(0)
  shippedQty     Int     @default(0)
  note           String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesOrder   SalesOrder   @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([salesOrderId])
}

// =========================
// Kit — kit/bundle definitions
// =========================
model Kit {
  id             String   @id @default(cuid())
  organizationId String
  parentItemId   String
  name           String
  description    String?
  type           KitType
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentItem   Item           @relation(fields: [parentItemId], references: [id], onDelete: Cascade)
  components   KitComponent[]

  @@unique([organizationId, parentItemId])
  @@index([organizationId])
  @@index([parentItemId])
}

// =========================
// KitComponent — kit components
// =========================
model KitComponent {
  id              String  @id @default(cuid())
  kitId           String
  componentItemId String
  variantId       String?
  quantity        Decimal @db.Decimal(10, 3)
  sortOrder       Int     @default(0)

  kit Kit @relation(fields: [kitId], references: [id], onDelete: Cascade)

  @@unique([kitId, componentItemId, variantId])
  @@index([kitId])
}

// =========================
// PickTask — directed pick tasks
// =========================
model PickTask {
  id               String     @id @default(cuid())
  organizationId   String
  salesOrderLineId String?
  itemId           String
  variantId        String?
  warehouseId      String
  fromBinId        String?
  quantity         Int
  status           PickStatus @default(PENDING)
  assignedToUserId String?
  pickedAt         DateTime?
  verifiedAt       DateTime?
  note             String?
  createdAt        DateTime   @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item           Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse      Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  assignedToUser User?        @relation(fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([assignedToUserId, status])
  @@index([itemId])
  @@index([warehouseId])
  @@index([assignedToUserId])
}

// =========================
// OrgSettings — org-level workflow/display configuration
// =========================
model OrgSettings {
  id                      String   @id @default(cuid())
  organizationId          String   @unique
  transferNumberPrefix    String   @default("TRF")
  transferNumberSequence  Int      @default(1)
  salesOrderPrefix        String   @default("SO")
  salesOrderSequence      Int      @default(1)
  assetTagPrefix          String   @default("FA")
  assetTagSequence        Int      @default(1)
  batchNumberPrefix       String   @default("LOT")
  batchNumberSequence     Int      @default(1)
  requireCountApproval    Boolean  @default(false)
  varianceThreshold       Decimal  @default(5.00) @db.Decimal(5, 2)
  recountOnThreshold      Boolean  @default(true)
  defaultCountMethodology String   @default("FULL")
  allowNegativeStock      Boolean  @default(false)
  defaultStockStatus      String   @default("AVAILABLE")
  dateFormat              String   @default("MM/DD/YYYY")
  currencySymbol          String   @default("$")
  updatedAt               DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// =========================
// ItemOptionGroup — variant option types (e.g. "Size", "Color")
// =========================
model ItemOptionGroup {
  id             String   @id @default(cuid())
  organizationId String
  itemId         String
  name           String
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item         Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  values       ItemOptionValue[]

  @@unique([itemId, name])
  @@index([organizationId, itemId])
  @@index([itemId])
}

// =========================
// ItemOptionValue — option values (e.g. "Small", "Red")
// =========================
model ItemOptionValue {
  id            String   @id @default(cuid())
  optionGroupId String
  value         String
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  optionGroup    ItemOptionGroup     @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)
  variantOptions ItemVariantOption[]

  @@unique([optionGroupId, value])
  @@index([optionGroupId])
}

// =========================
// ItemVariant — specific product variant
// =========================
model ItemVariant {
  id             String     @id @default(cuid())
  organizationId String
  itemId         String
  sku            String
  name           String?
  costPrice      Decimal?   @db.Decimal(12, 2)
  salePrice      Decimal?   @db.Decimal(12, 2)
  weight         Decimal?   @db.Decimal(10, 3)
  imageUrl       String?
  status         ItemStatus @default(ACTIVE)
  isDefault      Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization  Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item          Item                   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  options       ItemVariantOption[]
  barcodes      ItemBarcode[]
  stockLevels   VariantStockLevel[]
  movements     VariantStockMovement[]
  transferLines StockTransferLine[]
  countEntries  CountEntry[]           @relation("EntryVariant")

  @@unique([organizationId, sku])
  @@index([organizationId, itemId])
  @@index([organizationId, status])
  @@index([itemId])
}

// =========================
// ItemVariantOption — junction: variant ↔ option values
// =========================
model ItemVariantOption {
  id            String @id @default(cuid())
  variantId     String
  optionValueId String

  variant     ItemVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue ItemOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
  @@index([variantId])
  @@index([optionValueId])
}

// =========================
// ItemBarcode — multiple barcodes per item/variant
// =========================
model ItemBarcode {
  id             String        @id @default(cuid())
  organizationId String
  itemId         String
  variantId      String?
  value          String
  format         BarcodeFormat
  type           BarcodeType
  label          String?
  multiplier     Int           @default(1)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item         Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  variant      ItemVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([organizationId, value])
  @@index([organizationId, itemId])
  @@index([organizationId, variantId])
  @@index([value])
  @@index([itemId])
  @@index([variantId])
}

// =========================
// VariantStockLevel — per-variant stock levels
// =========================
model VariantStockLevel {
  id             String   @id @default(cuid())
  organizationId String
  variantId      String
  warehouseId    String
  binId          String?
  quantity       Int      @default(0)
  reservedQty    Int      @default(0)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  variant      ItemVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([variantId, warehouseId, binId])
  @@index([organizationId])
  @@index([variantId])
  @@index([warehouseId])
  @@index([binId])
}

// =========================
// VariantStockMovement — variant-level movements
// =========================
model VariantStockMovement {
  id              String            @id @default(cuid())
  organizationId  String
  variantId       String
  itemId          String
  warehouseId     String
  binId           String?
  toWarehouseId   String?
  toBinId         String?
  type            StockMovementType
  quantity        Int
  direction       Int               @default(1)
  reference       String?
  note            String?
  idempotencyKey  String?
  stockCountId    String?
  createdByUserId String?
  createdAt       DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  variant      ItemVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, variantId])
  @@index([organizationId, createdAt])
  @@index([organizationId, type])
  @@index([variantId])
  @@index([itemId])
  @@index([warehouseId])
  @@index([binId])
  @@index([toWarehouseId])
  @@index([toBinId])
  @@index([createdByUserId])
}

// =========================
// FixedAsset — fixed asset register
// =========================
model FixedAsset {
  id               String        @id @default(cuid())
  organizationId   String
  itemId           String?
  assetTag         String
  name             String
  description      String?
  serialNumber     String?
  category         AssetCategory
  status           AssetStatus   @default(ACTIVE)
  purchaseDate     DateTime?
  purchaseCost     Decimal?      @db.Decimal(12, 2)
  currentValue     Decimal?      @db.Decimal(12, 2)
  depreciationRate Decimal?      @db.Decimal(5, 2)
  warrantyExpiry   DateTime?
  assignedToUserId String?
  warehouseId      String?
  binId            String?
  barcodeValue     String?
  imageUrl         String?
  notes            String?
  lastAuditedAt    DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item         Item?          @relation(fields: [itemId], references: [id], onDelete: SetNull)
  assignedTo   User?          @relation("AssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  warehouse    Warehouse?     @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  history      AssetHistory[]

  @@unique([organizationId, assetTag])
  @@index([organizationId, status])
  @@index([organizationId, category])
  @@index([organizationId, assignedToUserId])
  @@index([barcodeValue])
  @@index([itemId])
  @@index([warehouseId])
}

// =========================
// AssetHistory — asset lifecycle events
// =========================
model AssetHistory {
  id                String      @id @default(cuid())
  organizationId    String
  assetId           String
  action            AssetAction
  fromUserId        String?
  toUserId          String?
  fromWarehouseId   String?
  toWarehouseId     String?
  note              String?
  performedByUserId String?
  performedAt       DateTime    @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  asset        FixedAsset   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([assetId, performedAt])
}

// =========================
// ItemBatch — batch/lot with expiry tracking
// =========================
model ItemBatch {
  id               String      @id @default(cuid())
  organizationId   String
  itemId           String
  variantId        String?
  batchNumber      String
  expiryDate       DateTime?
  manufactureDate  DateTime?
  receivedDate     DateTime?
  supplierBatchRef String?
  warehouseId      String
  binId            String?
  quantity         Int
  initialQuantity  Int
  costPrice        Decimal?    @db.Decimal(12, 2)
  status           BatchStatus @default(AVAILABLE)
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item           Item                @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse      Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  // Back-references for V4 tracking
  stockMovements StockMovement[]     @relation("MovementBatch")
  countEntries   CountEntry[]        @relation("EntryBatch")
  transferLines  StockTransferLine[]

  @@unique([organizationId, itemId, batchNumber])
  @@index([organizationId, itemId])
  @@index([organizationId, expiryDate])
  @@index([organizationId, status])
  @@index([warehouseId])
  @@index([itemId])
  @@index([variantId])
  @@index([binId])
}

// =========================
// CountZone — temporary zones during counts (from V2)
// =========================
model CountZone {
  id              String        @id @default(cuid())
  organizationId  String
  countId         String
  name            String
  code            String?
  barcodeValue    String?
  barcodeFormat   BarcodeFormat @default(QR)
  color           String?
  description     String?
  warehouseId     String?
  parentZoneId    String?
  sortOrder       Int           @default(0)
  isArchived      Boolean       @default(false)
  promoteToBin    Boolean       @default(false)
  createdByUserId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  count        StockCount   @relation(fields: [countId], references: [id], onDelete: Cascade)
  warehouse    Warehouse?   @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  parentZone   CountZone?   @relation("ZoneHierarchy", fields: [parentZoneId], references: [id], onDelete: SetNull)
  childZones   CountZone[]  @relation("ZoneHierarchy")
  createdBy    User?        @relation("ZoneCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  entries      CountEntry[]
  labels       ZoneLabel[]

  @@unique([countId, code])
  @@index([organizationId, countId])
  @@index([countId, isArchived])
  @@index([warehouseId])
  @@index([parentZoneId])
  @@index([createdByUserId])
}

// =========================
// ZoneLabel — printed labels for temp zones
// =========================
model ZoneLabel {
  id              String    @id @default(cuid())
  zoneId          String
  templateId      String?
  printedAt       DateTime?
  printedByUserId String?
  copies          Int       @default(1)
  createdAt       DateTime  @default(now())

  zone      CountZone      @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  template  LabelTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  printedBy User?          @relation("PrintedBy", fields: [printedByUserId], references: [id], onDelete: SetNull)

  @@index([zoneId])
  @@index([templateId])
  @@index([printedByUserId])
}

// =========================
// MigrationJob — competitor migration tracking (from V2)
// =========================
model MigrationJob {
  id               String          @id @default(cuid())
  organizationId   String
  sourcePlatform   MigrationSource
  status           MigrationStatus @default(PENDING)
  sourceFiles      Json?
  fieldMappings    Json?
  validationReport Json?
  importResults    Json?
  // Phase MIG-S1 — Per-job scope decisions made by the user in the
  // wizard's "Göç Kapsamı" step. Schema (validated by Zod in
  // src/lib/migrations/core/scope-options.ts):
  //   {
  //     poHistory: "ALL" | "LAST_12_MONTHS" | "OPEN_ONLY" | "SKIP",
  //     includeCustomFields: boolean,
  //     includeAttachments: boolean,
  //     includeArchivedItems: boolean,
  //     dateRangeStart?: ISO8601 string
  //   }
  // Kept as Json (not enum) so future sprints can add scope flags
  // (salesOrderHistory, serialNumberHistory, ...) without DDL.
  scopeOptions     Json?
  startedAt        DateTime?
  completedAt      DateTime?
  createdByUserId  String?
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("MigrationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([createdByUserId])
}

// =========================
// Phase MIG-S1: CustomFieldDefinition + ItemCustomFieldValue
// =========================
//
// Sortly, inFlow, and Fishbowl all let users define custom columns
// on their items (e.g. "Garanti süresi", "Tedarikçi parça no",
// "Tehlikeli madde sınıfı"). To preserve those during migration —
// and to give OneAce-native users the same capability — we store
// them in a typed schema rather than a free-form JSON blob:
//
//   CustomFieldDefinition (per-org schema row, e.g. "warranty_months: NUMBER")
//      └── ItemCustomFieldValue (per-item value, exactly one typed column populated)
//
// The (organizationId, entityType, fieldKey) unique guarantees a stable
// API surface ("?customField.warranty_months=24"). The
// (externalSource, externalId) pair on the definition lets the migration
// engine match existing custom fields on re-import (idempotent).
model CustomFieldDefinition {
  id             String            @id @default(cuid())
  organizationId String
  entityType     CustomFieldEntity
  name           String // human label, e.g. "Garanti süresi"
  fieldKey       String // slug, e.g. "warranty_months"
  fieldType      CustomFieldType
  options        Json? // for SELECT / MULTI_SELECT (string[])
  isRequired     Boolean           @default(false)
  defaultValue   String?
  sortOrder      Int               @default(0)
  // Migration provenance — set when the definition originated in a
  // competitor export so re-imports can find-or-update instead of
  // creating duplicates. Both null for OneAce-native fields.
  externalSource MigrationSource?
  externalId     String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itemValues   ItemCustomFieldValue[]

  @@unique([organizationId, entityType, fieldKey], name: "ux_cfdef_org_entity_key")
  @@unique([organizationId, externalSource, externalId], name: "ux_cfdef_external")
  @@index([organizationId, entityType])
}

model ItemCustomFieldValue {
  id           String    @id @default(cuid())
  itemId       String
  definitionId String
  // Exactly one of these is populated based on definition.fieldType.
  // The application layer enforces the constraint; Postgres does not
  // (a CHECK constraint would force a migration every time a new
  // CustomFieldType ships). Reading code MUST consult the definition.
  valueText    String?
  valueNumber  Decimal?  @db.Decimal(20, 6)
  valueDate    DateTime?
  valueBoolean Boolean?
  valueJson    Json? // MULTI_SELECT array of selected option keys
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  item       Item                  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  definition CustomFieldDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@unique([itemId, definitionId], name: "ux_cfval_item_def")
  @@index([definitionId])
  @@index([itemId])
}
