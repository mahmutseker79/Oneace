// OneAce Prisma Schema
// Sprint 0: Auth + multi-tenancy foundation (User, Organization, Membership, Better Auth tables).
// Sprint 1: Warehouse, Category, Item, StockLevel — core inventory domain.
// Sprint 2: StockMovement — append-only ledger with transactional level recompute.
// Sprint 3: StockCount + CountSnapshot + CountEntry — physical count with
//           variance reconciliation and automatic ledger adjustments. This
//           is the moat feature: counting that feels like a first-class
//           workflow with a variance preview, six methodologies, and an
//           honest audit trail.
// Later sprints expand this — see OneAce_Roadmap.md for the full model outline.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =========================
// Tenant & Membership
// =========================

model Organization {
  id                 String              @id @default(cuid())
  name               String
  slug               String              @unique
  plan               Plan                @default(FREE)
  // Phase 12.3 — Stripe billing. Nullable: only set once an org initiates
  // checkout. Used to look up the Stripe customer on billing portal entry
  // and webhook reconciliation. Null = no Stripe customer yet (FREE plan,
  // no payment method added).
  stripeCustomerId   String?             @unique
  // Phase 12.3 — Tracks the current Stripe subscription id so the webhook
  // handler can match subscription events back to the organization without
  // a stripeCustomerId round-trip.
  stripeSubscriptionId String?           @unique
  // Sprint 19: per-org fallback for interface language + region.
  // `null` means "no org-level override; fall through to the
  // Accept-Language header / platform default". Validated at the
  // server-action layer against SUPPORTED_LOCALES / SUPPORTED_REGIONS
  // so a rogue admin-CLI write can't poison the i18n resolver.
  defaultLocale      String?
  defaultRegion      String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  memberships        Membership[]
  warehouses         Warehouse[]
  categories         Category[]
  items              Item[]
  stockLevels        StockLevel[]
  stockMovements     StockMovement[]
  stockCounts        StockCount[]
  countSnapshots     CountSnapshot[]
  countEntries       CountEntry[]
  suppliers          Supplier[]
  purchaseOrders     PurchaseOrder[]
  purchaseOrderLines PurchaseOrderLine[]
  // Sprint 20: outstanding / historical invitations for this org.
  invitations        Invitation[]
  // Sprint 36: append-only audit trail scoped to this org.
  auditEvents        AuditEvent[]
  // P10.2: alerts and notifications scoped to this org.
  alerts             Alert[]
  notifications      Notification[]

  @@index([slug])
}

model Membership {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           Role         @default(MEMBER)
  createdAt      DateTime     @default(now())
  // Phase 5A — additive nullable column. NOT wired into any read or
  // write path yet; reserving the namespace so a future "soft-disable
  // teammate" feature does not need another migration against a
  // larger table. Historical rows are `null` (active). When the
  // feature ships, every `requireActiveMembership` / membership-list
  // query will need an explicit `deactivatedAt: null` filter — the
  // column on its own changes nothing today.
  deactivatedAt  DateTime?
  // P7.2 — Per-member UI state (bridge visits, dismissed flags, etc.)
  // Additive nullable Json column. Existing rows are `null` (no UI
  // state recorded). Parsed as `{ bridgeVisits?: number;
  // bridgeDismissed?: boolean }` in application code.
  uiState        Json?
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

// =========================
// Sprint 20: Invitation
// =========================
//
// An Invitation represents a pending (or historical) invite to join
// an organization. The flow is:
//   1. An OWNER/ADMIN creates an Invitation row with a random token.
//   2. They copy/share the invite URL `/invite/{token}` manually.
//      (Email sending is deferred to post-MVP — we intentionally don't
//      ship an SMTP dependency inside the MVP window.)
//   3. The invitee signs in with a matching email and hits the
//      `/invite/{token}` page, which calls `acceptInvitationAction`
//      to create the Membership and stamp `acceptedAt` / `acceptedById`.
//
// We keep revoked and accepted rows around rather than deleting them
// so that the pending-invitations list stays auditable ("Ana's invite
// from last week was revoked by Ben") and so that a stale URL fails
// with a clear "already accepted / revoked" message instead of a
// generic 404.
//
// `email` is stored lowercased. `(organizationId, email)` is **not**
// unique — an admin might reasonably need to re-issue an invite after
// one is revoked, and keeping the old row alongside the new one is
// fine. The server-action layer enforces "no two *pending* invites
// for the same email in the same org" manually.
model Invitation {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  role           Role
  token          String    @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  acceptedById   String?
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitationsSent", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedBy   User?        @relation("InvitationsAccepted", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([email])
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

// =========================
// Better Auth tables
// https://www.better-auth.com/docs/concepts/database
// =========================

model User {
  id                  String          @id @default(cuid())
  email               String          @unique
  name                String?
  emailVerified       Boolean         @default(false)
  image               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  sessions            Session[]
  accounts            Account[]
  memberships         Membership[]
  stockMovements      StockMovement[]
  stockCounts         StockCount[]
  countEntries        CountEntry[]
  purchaseOrders      PurchaseOrder[]
  // Sprint 20: invitations this user has sent / accepted.
  invitationsSent     Invitation[]    @relation("InvitationsSent")
  invitationsAccepted Invitation[]    @relation("InvitationsAccepted")
  // Sprint 36: audit events authored by this user (nullable actor on the
  // other side so system-generated events can persist after the user row
  // is deleted).
  auditEventsLogged   AuditEvent[]
  // P10.2: per-user notifications
  notifications       Notification[]

  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

// =========================
// Inventory Domain (Sprint 1)
// =========================

model Warehouse {
  id                  String          @id @default(cuid())
  organizationId      String
  name                String
  code                String
  address             String?
  city                String?
  region              String?
  country             String?
  isDefault           Boolean         @default(false)
  isArchived          Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  organization        Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bins                Bin[]
  stockLevels         StockLevel[]
  movements           StockMovement[] @relation("MovementFromWarehouse")
  movementsTransferIn StockMovement[] @relation("MovementToWarehouse")
  stockCounts         StockCount[]
  countSnapshots      CountSnapshot[]
  countEntries        CountEntry[]
  purchaseOrders      PurchaseOrder[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

// =========================
// Bin (sub-location within a warehouse) — P9.2
// =========================
//
// A bin is a named slot within a warehouse: a shelf, rack, aisle, or
// zone. Bins are optional — an organization can ignore them entirely
// and all stock stays at the warehouse level (binId = null on
// StockLevel, StockMovement, CountEntry).
//
// Bin codes follow the convention "zone-aisle-shelf" but the schema
// accepts any alphanumeric+dash string; the UI enforces a pattern
// only for guidance.
model Bin {
  id            String        @id @default(cuid())
  warehouseId   String
  code          String
  label         String?
  description   String?
  isArchived    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  warehouse     Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  stockLevels   StockLevel[]
  movements     StockMovement[] @relation("MovementFromBin")
  movementsIn   StockMovement[] @relation("MovementToBin")
  countEntries  CountEntry[]

  @@unique([warehouseId, code])
  @@index([warehouseId])
}

model Category {
  id             String       @id @default(cuid())
  organizationId String
  parentId       String?
  name           String
  slug           String
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         Category?    @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children       Category[]   @relation("CategoryChildren")
  items          Item[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([parentId])
}

model Item {
  id                  String              @id @default(cuid())
  organizationId      String
  categoryId          String?
  preferredSupplierId String?
  sku                 String
  barcode             String?
  name                String
  description         String?
  unit                String              @default("each")
  costPrice           Decimal?            @db.Decimal(12, 2)
  salePrice           Decimal?            @db.Decimal(12, 2)
  currency            String              @default("USD")
  reorderPoint        Int                 @default(0)
  reorderQty          Int                 @default(0)
  status              ItemStatus          @default(ACTIVE)
  imageUrl            String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category            Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  preferredSupplier   Supplier?           @relation("ItemPreferredSupplier", fields: [preferredSupplierId], references: [id], onDelete: SetNull)
  stockLevels         StockLevel[]
  movements           StockMovement[]
  countSnapshots      CountSnapshot[]
  countEntries        CountEntry[]
  purchaseOrderLines  PurchaseOrderLine[]
  // P10.2: low-stock alerts for this item
  alerts              Alert[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([organizationId, barcode])
  @@index([organizationId, status])
  @@index([organizationId, preferredSupplierId])
}

enum ItemStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

// Per-warehouse quantity snapshot. Stock movements (Sprint 2) append-only
// write to the StockMovement table and the create action atomically
// upserts these rows inside the same transaction.
model StockLevel {
  id             String       @id @default(cuid())
  organizationId String
  itemId         String
  warehouseId    String
  binId          String?
  quantity       Int          @default(0)
  reservedQty    Int          @default(0)
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item           Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse      Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  bin            Bin?         @relation(fields: [binId], references: [id], onDelete: SetNull)

  // Unique constraint updated: (item, warehouse, bin) — null bin = warehouse-level.
  // Existing rows have binId=null and remain valid.
  @@unique([itemId, warehouseId, binId])
  @@index([organizationId])
  @@index([warehouseId])
  @@index([binId])
}

// =========================
// Stock Movement Ledger (Sprint 2)
// =========================
//
// Append-only ledger for every stock change. Four types at MVP:
//   RECEIPT    — goods in from a supplier / external source  (+)
//   ISSUE      — goods out to a customer / external sink      (-)
//   ADJUSTMENT — manual correction, signed quantity           (+/-)
//   TRANSFER   — internal move between two warehouses
//                (warehouseId = from, toWarehouseId = to)
//
// COUNT movements (Sprint 3) will record the net delta from a reconciled
// stock count cycle.
//
// The `quantity` field is always positive. For ISSUE and negative
// adjustments the server action inverts the sign before applying it to
// StockLevel. This keeps the ledger readable while letting the app
// compute signed deltas from (type, quantity, direction).
//
// All stock level updates happen inside a prisma $transaction alongside
// the movement insert, so the ledger and the snapshot can never diverge.
model StockMovement {
  id                  String             @id @default(cuid())
  organizationId      String
  itemId              String
  warehouseId         String
  binId               String?
  toWarehouseId       String?
  toBinId             String?
  type                StockMovementType
  // Always positive. Direction derived from `type` + `direction`.
  quantity            Int
  // +1 or -1. Only meaningful for ADJUSTMENT; other types imply their own
  // sign (RECEIPT → +1, ISSUE → -1, TRANSFER → +1 for destination / -1
  // for source).
  direction           Int                @default(1)
  reference           String?
  note                String?
  // Sprint 26 — PWA Sprint 4 Part B. Client-generated UUID that serves as
  // the idempotency key for offline replay. Nullable because (a) online
  // fast-path writes through the legacy FormData action don't need it,
  // and (b) every movement inserted before Sprint 26 has `null` here. The
  // compound unique index below guarantees that a replay from a queued
  // op can never double-apply: the second insert violates the constraint
  // and the action handler returns the existing row's id. Scoped by
  // organizationId so a leaked key from one tenant can't collide with
  // another tenant's key.
  idempotencyKey      String?
  // Phase 5A — source-document backrefs. Both are additive and
  // nullable. Historical rows (pre-Phase-5A) have `null` for both
  // and are NOT backfilled — any report that filters on one of these
  // only sees movements written on or after the Phase 5A migration.
  //
  //   purchaseOrderLineId — set by `receivePurchaseOrderAction` on the
  //     RECEIPT movements it creates. Lets the ledger join back to the
  //     originating PO line without parsing `reference`.
  //   stockCountId — set by `completeStockCountAction` on the
  //     ADJUSTMENT movements it creates. Count-generated movements keep
  //     `type = ADJUSTMENT` (not COUNT) for backwards compatibility;
  //     this column is the discriminator a reader uses to tell a
  //     manual adjustment from a reconcile-generated one.
  purchaseOrderLineId String?
  stockCountId        String?
  createdAt           DateTime           @default(now())
  createdByUserId     String?
  organization        Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item                Item               @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse           Warehouse          @relation("MovementFromWarehouse", fields: [warehouseId], references: [id], onDelete: Cascade)
  bin                 Bin?               @relation("MovementFromBin", fields: [binId], references: [id], onDelete: SetNull)
  toWarehouse         Warehouse?         @relation("MovementToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Cascade)
  toBin               Bin?               @relation("MovementToBin", fields: [toBinId], references: [id], onDelete: SetNull)
  createdBy           User?              @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  // SetNull on both: the ledger is append-only and must survive the
  // deletion of the originating document. A PO line or stock count
  // being deleted later does not invalidate the stock movement it
  // produced — the stock change already happened.
  purchaseOrderLine   PurchaseOrderLine? @relation(fields: [purchaseOrderLineId], references: [id], onDelete: SetNull)
  stockCount          StockCount?        @relation(fields: [stockCountId], references: [id], onDelete: SetNull)

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, createdAt])
  @@index([organizationId, itemId])
  @@index([organizationId, warehouseId])
  @@index([organizationId, type])
  @@index([organizationId, purchaseOrderLineId])
  @@index([organizationId, stockCountId])
}

enum StockMovementType {
  RECEIPT
  ISSUE
  ADJUSTMENT
  TRANSFER
  COUNT
  BIN_TRANSFER
}

// =========================
// Stock Counting (Sprint 3) — the moat
// =========================
//
// A count is a frozen-in-time snapshot of expected quantities for a set of
// items in one (or all) warehouses, plus an append-only log of "here's what
// I physically counted" entries. When the supervisor reconciles the count,
// variances become ADJUSTMENT movements in the existing ledger — the
// StockCount + ADJUSTMENT pair is the audit trail.
//
// State machine: open -> in_progress -> completed | cancelled
//   - open: just created, no entries yet.
//   - in_progress: auto-transitioned after the first entry.
//   - completed: reconciled. Terminal.
//   - cancelled: aborted with a reason. Terminal. Snapshot + entries kept
//     for audit.
//
// Blind and double-blind methodologies hide the expected quantity in the
// UI but the snapshot is still persisted — blindness is a view-time rule,
// not a data rule.

model StockCount {
  id              String           @id @default(cuid())
  organizationId  String
  warehouseId     String?
  name            String
  state           StockCountState  @default(OPEN)
  methodology     CountMethodology @default(CYCLE)
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  createdByUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  warehouse       Warehouse?       @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  createdBy       User?            @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  snapshots       CountSnapshot[]
  entries         CountEntry[]
  // Phase 5A — back-relation for the `stockCountId` FK on StockMovement.
  // Populated only from `completeStockCountAction` reconcile path.
  movements       StockMovement[]

  @@index([organizationId, state])
  @@index([organizationId, createdAt])
  @@index([warehouseId])
}

// One row per (count, item, warehouse) frozen at create time. The
// `expectedQuantity` never changes once the count leaves the OPEN state;
// it's the reference point variance is measured against.
model CountSnapshot {
  id               String       @id @default(cuid())
  organizationId   String
  countId          String
  itemId           String
  warehouseId      String
  expectedQuantity Int
  createdAt        DateTime     @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  count            StockCount   @relation(fields: [countId], references: [id], onDelete: Cascade)
  item             Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse        Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  // Phase 5A — back-relation for the composite FK on CountEntry.
  // Codifies the invariant the action layer already enforces
  // (`writeCountEntry` refuses to create an entry when no matching
  // snapshot exists). With this FK in place a stray write — a future
  // import path, a manual SQL insert — cannot bypass it.
  entries          CountEntry[] @relation("CountEntrySnapshot")

  @@unique([countId, itemId, warehouseId])
  @@index([countId])
  @@index([organizationId])
}

// Append-only log of physical count entries. Multiple entries per
// (count, item) are allowed and are summed at reconcile time — this
// lets a counter scan the same SKU several times across a shift
// without deleting anything.
model CountEntry {
  id              String        @id @default(cuid())
  organizationId  String
  countId         String
  itemId          String
  warehouseId     String
  binId           String?
  countedQuantity Int
  counterTag      String?
  note            String?
  countedAt       DateTime      @default(now())
  countedByUserId String?
  // Sprint 27 (PWA Sprint 4 follow-on): client-generated UUID v4 used as a
  // cross-tenant-unique idempotency key so offline replays of the same
  // addCountEntry op don't create duplicates. Nullable for backfill safety;
  // compound unique with organizationId for race-free pre-check + P2002 replay.
  idempotencyKey  String?
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  count           StockCount    @relation(fields: [countId], references: [id], onDelete: Cascade)
  item            Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  warehouse       Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  bin             Bin?          @relation(fields: [binId], references: [id], onDelete: SetNull)
  countedBy       User?         @relation(fields: [countedByUserId], references: [id], onDelete: SetNull)
  // Phase 5A — composite FK to the owning CountSnapshot row. This is
  // a SECOND FK over the same three scalar fields (Postgres happily
  // supports multiple FKs on the same column), using the
  // `@@unique([countId, itemId, warehouseId])` on CountSnapshot as
  // its target. Cascade on delete matches the row-level cascade from
  // `count` above — if the snapshot goes because the count was
  // deleted, its entries go with it.
  snapshot        CountSnapshot @relation("CountEntrySnapshot", fields: [countId, itemId, warehouseId], references: [countId, itemId, warehouseId], onDelete: Cascade)

  @@unique([organizationId, idempotencyKey])
  @@index([countId, countedAt])
  @@index([countId, itemId])
  @@index([organizationId])
}

enum StockCountState {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CountMethodology {
  CYCLE
  FULL
  SPOT
  BLIND
  DOUBLE_BLIND
  DIRECTED
}

// =========================
// Suppliers + Purchase Orders (Sprint 5)
// =========================
//
// The receiving side of the inventory loop. A PurchaseOrder is a header
// (supplier, warehouse, currency, status, dates) with one or more
// PurchaseOrderLine rows. Receiving a PO is an atomic operation:
//
//   1. Update each line's receivedQty
//   2. Append a StockMovement(type=RECEIPT) for each line that had a
//      delta this receive cycle
//   3. Upsert StockLevel for (item, warehouse)
//   4. Transition the PO status based on the new per-line totals:
//        - all lines fully received → RECEIVED
//        - any line partially received → PARTIALLY_RECEIVED
//        - no lines received → unchanged
//
// Partial receipts are the common case in real warehouses — suppliers
// often ship in multiple drops — so the state machine is permissive.
// A CANCELLED PO is terminal; a RECEIVED PO is terminal. A
// PARTIALLY_RECEIVED PO can continue to receive until fully received
// or manually cancelled.

model Supplier {
  id             String          @id @default(cuid())
  organizationId String
  name           String
  code           String? // optional short code (e.g. "ACME")
  contactName    String?
  email          String?
  phone          String?
  addressLine1   String?
  addressLine2   String?
  city           String?
  region         String?
  postalCode     String?
  country        String?
  website        String?
  notes          String?
  currency       String          @default("USD")
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  items          Item[]          @relation("ItemPreferredSupplier")
  purchaseOrders PurchaseOrder[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([organizationId, name])
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  organizationId  String
  supplierId      String
  warehouseId     String // destination warehouse
  poNumber        String // human-readable, unique per org
  status          PurchaseOrderStatus @default(DRAFT)
  currency        String              @default("USD")
  orderedAt       DateTime            @default(now())
  expectedAt      DateTime?
  receivedAt      DateTime? // set when status hits RECEIVED
  cancelledAt     DateTime?
  cancelReason    String?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  createdByUserId String?
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  supplier        Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  warehouse       Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  createdBy       User?               @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines           PurchaseOrderLine[]

  @@unique([organizationId, poNumber])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, supplierId])
  @@index([organizationId, warehouseId])
  @@index([organizationId, orderedAt])
}

model PurchaseOrderLine {
  id              String          @id @default(cuid())
  organizationId  String
  purchaseOrderId String
  itemId          String
  orderedQty      Int
  receivedQty     Int             @default(0)
  unitCost        Decimal         @db.Decimal(12, 2)
  note            String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchaseOrder   PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  item            Item            @relation(fields: [itemId], references: [id], onDelete: Restrict)
  // Phase 5A — back-relation for the `purchaseOrderLineId` FK on
  // StockMovement. Populated only from `receivePurchaseOrderAction`.
  // A single PO line can have many receive events (partial receipts).
  movements       StockMovement[]

  @@index([purchaseOrderId])
  @@index([organizationId])
  @@index([itemId])
}

enum PurchaseOrderStatus {
  DRAFT // being edited, no stock impact
  SENT // sent to supplier, awaiting delivery
  PARTIALLY_RECEIVED // some lines received
  RECEIVED // all lines received, terminal
  CANCELLED // cancelled, terminal
}

// =========================
// Sprint 36: Audit log
// =========================
//
// An append-only ledger of interesting mutations scoped to an organization.
// Sprint 36 wires this into the high-severity actions (org lifecycle,
// membership/invitation lifecycle, purchase-order lifecycle); the rest of
// the surface area (items / warehouses / stock movements / counts) is a
// follow-up sprint. Rows are never updated or deleted from application
// code — the `/audit` reviewer reads them chronologically.
//
// Design notes
// ------------
// 1. `organizationId` is required so rows are always scoped to a tenant.
//    The `/audit` page filters on the active membership's org.
// 2. `actorId` is nullable: we keep the row even if the user is later
//    deleted (SetNull), and system/cron-generated events can legitimately
//    have no actor.
// 3. `action` is a free-form short verb ("organization.updated",
//    "purchase_order.received"); we don't use an enum so new actions can
//    be added without a migration. The `/audit` UI groups/filters by
//    prefix (everything before the dot).
//
//    Vocabulary sync contract (load-bearing — Phase 5A):
//      The canonical list of valid `action` / `entityType` strings is
//      the `AuditAction` / `AuditEntityType` TypeScript union in
//      `src/lib/audit.ts`. Every value in that union MUST also have a
//      label key in `src/lib/i18n/messages/en.ts` under
//      `audit.actions.<value>`, because the `/audit` and
//      `/purchase-orders/[id]` pages type their label catalog as
//      `Record<AuditAction, string>` — a missing key is a tsc failure.
//      Adding a new audit event is therefore a three-place change:
//      (a) extend the union in audit.ts, (b) add the catalog entry in
//      en.ts, (c) call `recordAudit({ action: "...", entityType: "..." })`
//      at the emission site. Phase 4A extended the vocabulary; Phase 5A
//      codifies this contract at the schema level so the next extender
//      sees it before the type-checker does.
// 4. `entityType` + `entityId` identify the subject row. `entityId` is
//    optional so we can also record org-wide events that don't map to a
//    single row (e.g. "organization.transferred"). Multi-entity events
//    (transfer, receive, reconcile) record their "other" subjects in
//    `metadata` today; a structured multi-subject model is Post-MVP.
// 5. `metadata Json?` carries the before/after diff, invoked parameters,
//    or any contextual details the action chose to record. Keep it small —
//    this is a log, not a data warehouse.
// 6. Composite index `(organizationId, createdAt)` supports the default
//    "latest first, cursor-paginated" query without a full scan; the
//    `(entityType, entityId)` index lets a future per-entity drill-down
//    filter cheaply.
model AuditEvent {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor        User?        @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entityType, entityId])
}

// =========================
// P10.2: Alerts & Notifications
// =========================
//
// An Alert represents a durable, condition-based signal scoped to an
// organization — currently LOW_STOCK alerts for items whose on-hand
// quantity falls at or below their reorder point. The lifecycle is:
//
//   ACTIVE → RESOLVED (auto, when stock recovers above reorder point)
//   ACTIVE → DISMISSED (manual, by a user from the notification center)
//
// Deduplication: a composite unique on (organizationId, itemId, type)
// filtered to ACTIVE alerts ensures at most one open alert per item
// per type. Resolved/dismissed alerts are kept for audit history.
//
// A Notification is a per-user record linked to an alert. When a new
// alert fires, notifications are fanned out to all OWNER/ADMIN/MEMBER
// roles in the org. A user can mark a notification as read (readAt),
// which does NOT resolve the underlying alert — resolution only happens
// when the condition clears.

model Alert {
  id             String      @id @default(cuid())
  organizationId String
  itemId         String
  type           AlertType   @default(LOW_STOCK)
  status         AlertStatus @default(ACTIVE)
  // Snapshot at trigger time — useful for history ("was 3, reorder at 10")
  threshold      Int         @default(0)
  currentQty     Int         @default(0)
  resolvedAt     DateTime?
  dismissedAt    DateTime?
  dismissedById  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  item         Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  notifications Notification[]

  // Only one ACTIVE alert per (org, item, type). The partial unique
  // below is PostgreSQL-specific (WHERE clause on the index). For
  // Prisma we enforce dedup in application code and add a regular
  // index + app-level check. The regular index supports fast lookups.
  @@index([organizationId, itemId, type, status])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

model Notification {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  alertId        String?
  title          String
  message        String
  href           String?  // click-through deep link, e.g. "/items/{id}"
  readAt         DateTime?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert        Alert?       @relation(fields: [alertId], references: [id], onDelete: SetNull)

  @@index([userId, readAt])
  @@index([organizationId, userId])
  @@index([alertId])
}

enum AlertType {
  LOW_STOCK
}

enum AlertStatus {
  ACTIVE
  RESOLVED
  DISMISSED
}
